# Stvor — required env vars
# Copy this file to .env.local and fill in your values.

# ── NVIDIA NIM ─────────────────────────────────────────────────────────────────
# API key from https://build.nvidia.com — used for Nemotron-3 Ultra agent inference
NVIDIA_API_KEY=nvapi-...

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Test-mode secret key from https://dashboard.stripe.com/test/apikeys
# Stvor uses capture_method: manual — funds are held, not captured, until attestation passes
STRIPE_SECRET_KEY=sk_test_...

# ── Stvor ECDSA signing keys ────────────────────────────────────────────────────
# Used to sign trust receipts (ECDSA P-256, SHA-256). ATS-1 §3 compliant.
# Generate with: node -e "const c=require('crypto'); const {privateKey,publicKey}=c.generateKeyPairSync('ec',{namedCurve:'prime256v1'}); console.log('PRIV:',privateKey.export({format:'der',type:'pkcs8'}).toString('base64')); console.log('PUB:',publicKey.export({format:'der',type:'spki'}).toString('base64'))"
STVOR_EC_PRIVATE_KEY_B64=
STVOR_EC_PUBLIC_KEY_B64=

# ── Upstash Redis (optional) ────────────────────────────────────────────────────
# Trust score persistence across Vercel cold starts. Leave blank for in-memory mode.
# Create a free database at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── SQLite path (optional) ─────────────────────────────────────────────────────
# Defaults to /tmp/stvor.db on Vercel. Set for persistent local storage.
# DB_PATH=/var/data/stvor.db
